# Optional absolute site URL for metadata + JSON-LD (defaults in layout).
NEXT_PUBLIC_SITE_URL=https://foodtruck.vercel.app

# Published Google Sheet CSV URL (server fetch). Prefer MENU_CSV_URL over NEXT_PUBLIC_*.
MENU_CSV_URL=
NEXT_PUBLIC_MENU_CSV_URL=

# Published Google Sheet CSV for locations (food truck + restaurant rows). Prefer LOCATIONS_CSV_URL.
LOCATIONS_CSV_URL=
NEXT_PUBLIC_LOCATIONS_CSV_URL=

# Clover (sandbox). Use production keys when going live.
NEXT_PUBLIC_CLOVER_PUBLIC_TOKEN_SANDBOX=
NEXT_PUBLIC_CLOVER_MERCHANT_ID_SANDBOX=
# sandbox | production
NEXT_PUBLIC_CLOVER_ENV=sandbox
